{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/proxy/argos",
        "function": "proxyArgosApi"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": "npm run build"
  }
}

